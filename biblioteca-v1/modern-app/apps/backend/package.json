{
  "name": "biblioteca-backend",
  "version": "1.0.0",
  "description": "Biblioteca REST API - Migrated from VB6",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "init-db": "tsx scripts/init-db.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/app.js",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.19.13",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.3"
  }
}
